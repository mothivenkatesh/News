# Ollama config (defaults work for a standard local install)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=300
OLLAMA_TEMP=0.3
OLLAMA_NUM_CTX=8192

# Pipeline config
CARDS_PER_RUN=20
MIN_IMPORTANCE=4         # cards below this score get dropped (1-3 = noise / off-topic)
MIN_FEED_SIZE=5          # but always keep at least this many even if all are below threshold
MAX_PER_SOURCE=2         # max cards per source per run (forces diversity)
MAX_PER_CATEGORY=3       # max cards per category per run (forces diversity)
HEADLINE_DEDUP_THRESHOLD=0.7   # post-LLM fuzzy dedup; 0=disabled, 1.0=exact match only
